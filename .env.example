# TP-Link / Tapo cloud credentials
TAPO_USERNAME=your_email@example.com
TAPO_PASSWORD=your_password

# Optional: static bulb IPs (comma-separated) to skip discovery
BULB_IPS=192.168.1.100,192.168.1.101

# Flask settings
FLASK_PORT=5000
FLASK_DEBUG=false

# Ngrok static domain (without https://)
NGROK_DOMAIN=your-domain.ngrok-free.dev

# API key for webhook authentication (generate a random string)
API_KEY=your_random_api_key_here
